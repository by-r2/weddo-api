          "item": [
            {
              "name": "confirm-rsvp",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"{{invitationCode}}\",\n  \"name\": \"João Silva\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/w/{{weddingId}}/rsvp",
                  "host": ["{{baseUrl}}"],
