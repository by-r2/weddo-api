          "name": "RSVP",
          "item": [
            {
              "name": "Confirmar Presença",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"João Silva\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/w/{{weddingId}}/rsvp",
                  "host": ["{{baseUrl}}"],
                  "path": ["w", "{{weddingId}}", "rsvp"]
                },
                "description": "Confirma presença buscando por nome exato (case-insensitive).\n\n- **200**: Confirmado com sucesso\n- **404**: Nome não encontrado\n- **409**: Já confirmado anteriormente"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200 ou 409', () => {",
                      "  pm.expect(pm.response.code).to.be.oneOf([200, 409]);",
                      "});",
                      "pm.test('Tem mensagem', () => {",
                      "  pm.expect(pm.response.json().message).to.be.a('string');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
