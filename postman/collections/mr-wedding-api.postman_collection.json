                  "host": ["{{baseUrl}}"],
                  "path": ["w", "{{weddingId}}", "rsvp", "invitation"],
                  "query": [
                    { "key": "name", "value": "João Silva", "description": "Nome exato do convidado" }
                  ]
                },
                "description": "Busca o convite pelo nome do convidado e retorna todos os convidados do mesmo convite com seus status."
              },
              "event": [
