                      "const body = pm.response.json();",
                      "if (body.data && body.data.length > 0) {",
                      "  pm.environment.set('giftId', body.data[0].id);",
                      "  pm.test('Só presentes available', () => {",
                      "    body.data.forEach(g => pm.expect(g.status).to.eql('available'));",
                      "  });",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Detalhar Presente (Público)",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/w/{{weddingId}}/gifts/{{giftId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["w", "{{weddingId}}", "gifts", "{{giftId}}"]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Comprar Presente (PIX)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payer_name\": \"Tia Maria\",\n  \"payer_email\": \"maria@email.com\",\n  \"message\": \"Felicidades ao casal!\",\n  \"payment_method\": \"pix\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/w/{{weddingId}}/gifts/{{giftId}}/purchase",
                  "host": ["{{baseUrl}}"],
                  "path": ["w", "{{weddingId}}", "gifts", "{{giftId}}", "purchase"]
                },
                "description": "Inicia pagamento via PIX. Retorna QR code e código copia-e-cola.\n\nRequer `MP_ACCESS_TOKEN` configurado no servidor."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 201 ou 503', () => {",
                      "  pm.expect(pm.response.code).to.be.oneOf([201, 503]);",
                      "});",
                      "",
                      "if (pm.response.code === 201) {",
                      "  const body = pm.response.json();",
                      "  pm.environment.set('paymentId', body.payment_id);",
                      "  pm.test('Tem QR code', () => pm.expect(body.qr_code).to.be.a('string'));",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Comprar Presente (Cartão)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payer_name\": \"Tia Maria\",\n  \"payer_email\": \"maria@email.com\",\n  \"message\": \"Felicidades ao casal!\",\n  \"payment_method\": \"credit_card\",\n  \"card_token\": \"TOKEN_DO_MERCADOPAGO_JS\",\n  \"payment_method_id\": \"visa\",\n  \"installments\": 1\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/w/{{weddingId}}/gifts/{{giftId}}/purchase",
                  "host": ["{{baseUrl}}"],
                  "path": ["w", "{{weddingId}}", "gifts", "{{giftId}}", "purchase"]
                },
                "description": "Inicia pagamento via cartão de crédito.\n\nO `card_token` é gerado pelo MercadoPago.js no frontend. Em sandbox, use tokens de teste do Mercado Pago."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 201 ou 503', () => {",
                      "  pm.expect(pm.response.code).to.be.oneOf([201, 503]);",
                      "});",
                      "",
                      "if (pm.response.code === 201) {",
                      "  pm.environment.set('paymentId', pm.response.json().payment_id);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ],
          "description": "Lista de presentes e fluxo de compra. Não requer autenticação."
        },
        {
          "name": "Payments",
          "item": [
            {
              "name": "Status do Pagamento",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/w/{{weddingId}}/payments/{{paymentId}}/status",
                  "host": ["{{baseUrl}}"],
                  "path": ["w", "{{weddingId}}", "payments", "{{paymentId}}", "status"]
                },
                "description": "Polling do status de um pagamento (usado enquanto aguarda PIX)."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Tem status', () => {",
                      "  pm.expect(pm.response.json().status).to.be.a('string');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ],
          "description": "Consulta pública de pagamentos."
        }
      ],
      "description": "Endpoints públicos. Não requerem autenticação. O tenant é identificado pelo `weddingId` na URL.",
      "auth": { "type": "noauth" }
    },
