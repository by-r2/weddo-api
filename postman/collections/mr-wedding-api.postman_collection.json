{
  "info": {
    "name": "mr-wedding-api",
    "description": "API multi-tenant para sites de casamento.\n\n## Setup\n\n1. Importe esta collection\n2. Importe o environment `mr-wedding-api.postman_environment.json`\n3. Rode o servidor: `make run`\n4. Execute **Admin > Login** para popular `token` e `weddingId` automaticamente\n5. Pronto — todas as requests usarão as variáveis automaticamente\n\n## Variáveis\n\n| Variável | Preenchida por | Uso |\n|----------|---------------|-----|\n| `baseUrl` | Environment | Base URL do servidor |\n| `token` | Login (auto) | Bearer token JWT |\n| `weddingId` | Login (auto) | UUID do tenant para endpoints públicos |\n| `invitationId` | Criar Convite (auto) | ID do último convite criado |\n| `guestId` | Listar Convidados (auto) | ID do primeiro convidado na lista |\n| `giftId` | Criar Presente (auto) | ID do último presente criado |\n| `paymentId` | Comprar Presente (auto) | ID do último pagamento criado |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verifica se o servidor está ativo. Não requer autenticação."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status ok', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ],
      "description": "Endpoint de monitoramento."
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Login",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/auth",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "auth"]
                },
                "description": "Autentica o admin e retorna JWT + dados do wedding.\n\nO token e weddingId são salvos automaticamente nas variáveis do environment."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "",
                      "if (pm.response.code === 200) {",
                      "  const body = pm.response.json();",
                      "  pm.environment.set('token', body.token);",
                      "  pm.environment.set('weddingId', body.wedding.id);",
                      "  pm.test('Token salvo', () => pm.expect(body.token).to.be.a('string'));",
                      "  pm.test('Wedding ID salvo', () => pm.expect(body.wedding.id).to.be.a('string'));",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Dashboard",
          "item": [
            {
              "name": "Dashboard",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/admin/dashboard",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "dashboard"]
                },
                "description": "Retorna estatísticas consolidadas de RSVP e presentes."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Tem stats de RSVP', () => {",
                      "  const body = pm.response.json();",
                      "  pm.expect(body.rsvp).to.have.property('total_guests');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Invitations",
          "item": [
            {
              "name": "Criar Convite",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"SILVA-001\",\n  \"label\": \"Família Silva\",\n  \"max_guests\": 3,\n  \"notes\": \"\",\n  \"guests\": [\n    { \"name\": \"João Silva\" },\n    { \"name\": \"Maria Silva\" },\n    { \"name\": \"Pedro Silva\" }\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/invitations",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "invitations"]
                },
                "description": "Cria um convite com convidados inline. O campo `guests` é opcional."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 201', () => pm.response.to.have.status(201));",
                      "",
                      "if (pm.response.code === 201) {",
                      "  const body = pm.response.json();",
                      "  pm.environment.set('invitationId', body.id);",
                      "  if (body.guests && body.guests.length > 0) {",
                      "    pm.environment.set('guestId', body.guests[0].id);",
                      "  }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Listar Convites",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/admin/invitations?page=1&per_page=20&search=",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "invitations"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "per_page", "value": "20" },
                    { "key": "search", "value": "", "description": "Busca por label ou code" }
                  ]
                },
                "description": "Lista convites com paginação e busca opcional."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Tem paginação', () => {",
                      "  pm.expect(pm.response.json().meta).to.have.property('total');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Detalhar Convite",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/admin/invitations/{{invitationId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "invitations", "{{invitationId}}"]
                },
                "description": "Retorna detalhes do convite com lista de convidados."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Atualizar Convite",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"SILVA-001\",\n  \"label\": \"Família Silva (atualizado)\",\n  \"max_guests\": 4,\n  \"notes\": \"Mesa 5\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/invitations/{{invitationId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "invitations", "{{invitationId}}"]
                },
                "description": "Atualiza os dados do convite (não altera guests)."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Adicionar Convidado ao Convite",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Ana Silva\",\n  \"phone\": \"11999998888\",\n  \"email\": \"ana@email.com\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/invitations/{{invitationId}}/guests",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "invitations", "{{invitationId}}", "guests"]
                },
                "description": "Adiciona um convidado a um convite existente."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 201', () => pm.response.to.have.status(201));",
                      "",
                      "if (pm.response.code === 201) {",
                      "  pm.environment.set('guestId', pm.response.json().id);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "Remover Convite",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/admin/invitations/{{invitationId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "invitations", "{{invitationId}}"]
                },
                "description": "Remove o convite e todos os convidados vinculados (cascade)."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 204', () => pm.response.to.have.status(204));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ],
          "description": "CRUD de convites. Cada convite agrupa convidados (família, casal, etc.)."
        },
