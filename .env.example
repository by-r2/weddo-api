# Guia completo: docs/configuration.md

# Servidor
SERVER_PORT=8080

# Banco de dados (Postgres — Supabase, Neon, local, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding?sslmode=disable

# JWT — GERE UM VALOR SEGURO: openssl rand -base64 32
JWT_SECRET=TROCAR-ANTES-DE-USAR
JWT_EXPIRATION_HOURS=24

# Wedding seed (cria o primeiro tenant no boot se não existir)
SEED_WEDDING_SLUG=manu-rafa
SEED_WEDDING_TITLE=Casamento Manoela & Rafael
SEED_WEDDING_DATE=2026-07-07
SEED_ADMIN_EMAIL=admin@manurafa.com.br
# GERE UMA SENHA SEGURA: openssl rand -base64 20
SEED_ADMIN_PASSWORD=TROCAR-ANTES-DE-USAR

# Provedor de pagamento: "infinitepay" ou "mercadopago" (vazio = desabilitado)
PAYMENT_PROVIDER=infinitepay

# InfinitePay — ver docs/configuration.md
IP_HANDLE=sua-infinite-tag
IP_REDIRECT_URL=http://localhost:3000/obrigado
IP_WEBHOOK_URL=http://localhost:8080/api/v1/payments/webhook

# Mercado Pago (alternativa) — ver docs/configuration.md
# MP_ACCESS_TOKEN=APP_USR-xxxx
# MP_WEBHOOK_SECRET=xxxx
# MP_NOTIFICATION_URL=http://localhost:8080/api/v1/payments/webhook
# MP_PIX_EXPIRATION_MINUTES=30

# CORS (origens separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# Logging (debug, info, warn, error)
LOG_LEVEL=debug
# Formato do log: text (dev) ou json (produção)
LOG_FORMAT=text

# Google Sheets OAuth por tenant (cada wedding conecta sua própria conta Google)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/sheets/connect/callback
# chave base64 de 32 bytes para criptografar tokens OAuth
# gerar: openssl rand -base64 32
GOOGLE_OAUTH_TOKEN_CIPHER_KEY=
# opcional (se vazio usa JWT_SECRET)
GOOGLE_OAUTH_STATE_SECRET=

# Postman CLI — usado por `make postman-push` para sincronizar com o Postman Cloud
# Gere em: https://go.postman.co/settings/me/api-keys
POSTMAN_API_KEY=
